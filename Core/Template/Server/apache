<VirtualHost __HOSTS__>
    DocumentRoot "__ROOT__"
    ServerAdmin __ADMIN__
    ServerName __NAME__
    ServerAlias __ALIAS__

    <Directory "__DIR__">
        AllowOverride All
    </Directory>

    <IfModule mod_fastcgi.c>
        <FilesMatch \.php$>
            SetHandler "proxy:unix:__PHP_FPM__|fcgi://localhost"
        </FilesMatch>
    </IfModule>

</VirtualHost>