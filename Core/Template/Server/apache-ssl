<VirtualHost __HOSTS__>
    # Redirect
    RewriteEngine On 
    RewriteCond %{HTTPS} off
    RewriteRule ^/?(.*) https://%{SERVER_NAME}/$1 [R=__REDIRECT_TYPE__,L] 
</VirtualHost>

<IfModule mod_ssl.c>
    <VirtualHost __HOSTS_SSL__>
        DocumentRoot "__ROOT__"
        ServerAdmin __ADMIN__
        ServerName __NAME__

        <Directory __DIR__>
            AllowOverride All
        </Directory>

        <IfModule mod_fastcgi.c>
            <FilesMatch \.php$>
                SetHandler "proxy:unix:__PHP_FPM__|fcgi://localhost"
            </FilesMatch>
        </IfModule>

        SSLEngine on
        SSLCertificateFile "__CERTIFICATE_FILE__"
        SSLCertificateKeyFile "__CERTIFICATE_KEY_FILE__"

        BrowserMatch "MSIE [2-5]" \
                    nokeepalive ssl-unclean-shutdown \
                    downgrade-1.0 force-response-1.0

    </VirtualHost>
</IfModule>