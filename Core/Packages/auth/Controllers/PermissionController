<?php

namespace Controllers;

use Extra\Src\Enum\HttpCode;
use Extra\Src\Enum\Method;
use Extra\Src\Enum\Request;
use Extra\Src\CDO\CDN;
use Extra\Src\Controller;
use Extra\Src\Route;
use Extra\Src\Wrapper;
use Extra\Src\Trait\CsrfTrait;
use Extra\Src\Trait\JsonResponseTrait;
use Models\Auth\PermissionModel;

class PermissionController extends Controller
{
    use CsrfTrait, JsonResponseTrait;
    public \Repositories\Auth\PermissionRepository $repo;

    protected function prepareAuth(bool $redirect = false): void
    {
        Route::isAuthAdmin($redirect);
    }

    public function index(): void
    {
        $this->method(Method::GET);
        $this->prepareAuth(1);
        $this->render('auth/permission/main');
    }

    public function list(): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();
        $this->repo->Limit(10, $_GET['CRD_page'] ?? 1);
        $this->view('auth/permission/table', Wrapper::paginatorDecoration($this->repo));
    }

    public function get(?string $pk = null): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();
        if ($pk) {
            $object = $this->repo->getBy(CDN::eq('name', $pk));
            if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not permission');
        } else $object = new PermissionModel();

        $this->view('auth/permission/form', array(
            'model' => formObject($object),
            'inputCsrf' => $this->csrfTokenInput()
        ));
    }

    public function hook(?string $pk = null): void
    {
        $this->method(Method::POST);
        $this->prepareAuth();
        $this->csrfTokenChange();

        $data = Request::post();
        $this->valid($data, 'name');
        $this->valid($data, 'description');

        if ( $pk ) {
            $object = $this->repo->getBy(CDN::eq('name', $pk));
            if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not permission');
            $object->reConstruct($data);
            $result = $this->repo->update($pk, $object);
        } else {
            $object = new PermissionModel($data);
            $result = $this->repo->save($object);
        }
        $this->renderJsonSuccess($result);
    }

    public function delete(string $pk): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();

        $object = $this->repo->getBy(CDN::eq('name', $pk));
        if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not permission');
        $this->repo->delete($pk);
        $this->renderJsonSuccess($pk);
    }

}