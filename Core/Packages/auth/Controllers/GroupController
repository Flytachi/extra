<?php

namespace Controllers;

use Extra\Src\Enum\HttpCode;
use Extra\Src\Enum\Method;
use Extra\Src\Enum\Request;
use Extra\Src\CDO\CDN;
use Extra\Src\Controller;
use Extra\Src\Route;
use Extra\Src\Wrapper;
use Extra\Src\Trait\CsrfTrait;
use Extra\Src\Trait\JsonResponseTrait;
use Models\Auth\GroupModel;
use Repositories\Auth\GroupPermissionRepository;
use Repositories\Auth\PermissionRepository;

class GroupController extends Controller
{
    use CsrfTrait, JsonResponseTrait;
    public \Repositories\Auth\GroupRepository $repo;

    protected function prepareAuth(bool $redirect = false): void
    {
        Route::isAuthAdmin($redirect);
    }

    public function index(): void
    {
        $this->method(Method::GET);
        $this->prepareAuth(1);
        $this->render('auth/group/main');
    }

    public function list(): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();
        $this->repo->Limit(10, $_GET['CRD_page'] ?? 1);
        $this->view('auth/group/table', Wrapper::paginatorDecoration($this->repo));
    }

    public function get(?int $pk = null): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();
        if ($pk) {
            $object = $this->repo->getBy(CDN::eq('id', $pk));
            if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not group');
        }
        else $object = new GroupModel;

        $this->view('auth/group/form', array(
            'model' => formObject($object),
            'permissionList' => (new PermissionRepository)->getAll(),
            'permission' => ($pk) ? (new GroupPermissionRepository)->getAllPermission($pk) : [],
            'inputCsrf' => $this->csrfTokenInput()
        ));
    }

    public function hook(?int $pk = null): void
    {
        $this->method(Method::POST);
        $this->prepareAuth();
        $this->csrfTokenChange();

        $data = Request::post();
        $this->valid($data, 'name');
        if (array_key_exists('permission', $data)) unset($data['permission']);

        if ( $pk ) {
            $object = $this->repo->getBy(CDN::eq('id', $pk));
            if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not group');
            $object->reConstruct($data);
            $result = $this->repo->update($pk, $object);
        } else {
            $object = new GroupModel($data);
            $result = $this->repo->save($object);
        }
        $this->renderJsonSuccess($result);
    }

    public function remove(int $pk): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();

        $object = $this->repo->getBy(CDN::eq('id', $pk));
        if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not group');

        $this->repo->delete($pk);
        $this->renderJsonSuccess($pk);
    }

}