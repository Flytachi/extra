<?php

namespace Controllers;

use Extra\Src\Enum\HttpCode;
use Extra\Src\Enum\HttpStatus;
use Extra\Src\Enum\Method;
use Extra\Src\Enum\Request;
use Extra\Src\CDO\CDN;
use Extra\Src\Controller;
use Extra\Src\Route;
use Extra\Src\Wrapper;
use Extra\Src\Trait\CsrfTrait;
use Extra\Src\Trait\JsonResponseTrait;
use Models\Auth\UserInfoModel;
use Models\Auth\UserModel;
use Repositories\Auth\GroupRepository;
use Repositories\Auth\UserInfoRepository;

class UserController extends Controller
{
    use CsrfTrait, JsonResponseTrait;
    public \Repositories\Auth\UserRepository $repo;

    protected function prepareAuth(bool $redirect = false): void
    {
        Route::isAuthAdmin($redirect);
    }

    public function index(): void
    {
        $this->method(Method::GET);
        $this->prepareAuth(1);
        if (!isPermission('user_view')) Route::Throwable(HttpCode::LOCKED, 'Permission "user_view" denied');
        $this->render('auth/user/main');
    }

    public function list(): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();
        if (!isPermission('user_view')) Route::Throwable(HttpCode::LOCKED, 'Permission "user_view" denied');
        $this->repo->as('u');
        $this->repo->Select("u.id, u.username, g.name 'group', ui.name, u.is_admin, u.is_delete");
        $this->repo->JoinLEFT(new \Repositories\Auth\UserInfoRepository('ui'), 'u.id=ui.user_id');
        $this->repo->JoinLEFT(new \Repositories\Auth\GroupRepository('g'), 'g.id=ui.group_id');
        $this->repo->Limit(10, $_GET['CRD_page'] ?? 1);
        $this->view('auth/user/table', Wrapper::paginatorDecoration($this->repo));
    }

    public function get(?int $pk = null): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();

        if ($pk) {
            if (!isPermission('user_update')) Route::Throwable(HttpCode::LOCKED, 'Permission "user_update" denied');
            $object = $this->repo->getBy(CDN::eq('id', $pk));
            if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not user');
            $info = (new UserInfoRepository)->isUser($pk);
            if (!$info) $info = new UserInfoModel;
        } else {
            if (!isPermission('user_create')) Route::Throwable(HttpCode::LOCKED, 'Permission "user_create" denied');
            $object = new UserModel;
            $info = new UserInfoModel;
        }
        $this->view('auth/user/form', [
            'model' => formObject($object),
            'userInfo' => formObject($info),
            'groupList' => (new GroupRepository)->getAll(),
            'inputCsrf' => $this->csrfTokeninput()
        ]);
    }

    public function changePassword(int $pk): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();
        $object = $this->repo->getBy(CDN::eq('id', $pk));
        if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not user');

        if (!$this->permissionChangePassword($object)) Route::Throwable(HttpCode::LOCKED, 'Permission denied.');
        $this->view('auth/user/passwordChange', array(
            'model' => $object,
            'inputCsrf' => $this->csrfTokenInput()
        ));
    }

    private function permissionChangePassword($user): bool
    {
        if (isAdmin()) return true;
        else return $user->id == $_SESSION['id'];
    }

    public function hook(?int $pk = null): void
    {
        $this->method(Method::POST);
        $this->prepareAuth();
        $this->csrfTokenChange();

        $data = Request::post();
        $this->valid($data, 'username');
        if (array_key_exists('permission', $data)) unset($data['permission']);

        if ( $pk ) {
            if (!isPermission('user_update')) Route::Throwable(HttpCode::LOCKED, 'Permission "user_update" denied');
            if (isset($data['info'])) unset($data['info']);
            $object = $this->repo->getBy(CDN::eq('id', $pk));
            if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not user');
            $object->reConstruct($data);
            $result = $this->repo->update($pk, $object);
        } else {
            if (!isPermission('user_create')) Route::Throwable(HttpCode::LOCKED, 'Permission "user_create" denied');
            if (isset($data['info'])) unset($data['info']);
            $object = new UserModel($data);
            $result = $this->repo->save($object);
        }
        $this->renderJsonSuccess($result);
    }

    public function hookPassword(int $pk): void
    {
        $this->method(Method::POST);
        $this->prepareAuth();
        $this->csrfTokenChange();

        $data = Request::post();
        $this->valid($data, 'password');
        $data['password'] = password_hash($data['password'], PASSWORD_BCRYPT);

        $object = $this->repo->getBy(CDN::eq('id', $pk));
        if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not user');
        if(!$this->permissionChangePassword($object)) Route::Throwable(HttpCode::LOCKED, 'Permission denied.');

        $object->reConstruct($data);
        $result = $this->repo->update($pk, $object);
        $this->renderJsonSuccess($result);
    }

    public function delete(int $pk): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();
        if (!isPermission('user_delete')) Route::Throwable(HttpCode::LOCKED, 'Permission "user_delete" denied');

        $object = $this->repo->getBy(CDN::and(
            CDN::eq('id', $pk),
            CDN::eq('is_delete', 0)
        ));
        if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not user');

        $object->reConstruct(['is_delete' => 1]);
        $result = $this->repo->update($pk, $object);
        $this->renderJsonSuccess($result);
    }

    public function restore(int $pk): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();
        if (!isPermission('user_restore')) Route::Throwable(HttpCode::LOCKED, 'Permission "user_restore" denied');

        $object = $this->repo->getBy(CDN::and(
            CDN::eq('id', $pk),
            CDN::eq('is_delete', 1)
        ));
        if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not user');

        $object->reConstruct(['is_delete' => 0]);
        $result = $this->repo->update($pk, $object);
        $this->renderJsonSuccess($result);
    }

    public function remove(int $pk): void
    {
        $this->method(Method::GET);
        $this->prepareAuth();
        if (!isPermission('user_remove')) Route::Throwable(HttpCode::LOCKED, 'Permission "user_remove" denied');

        $object = $this->repo->getBy(CDN::eq('id', $pk));
        if (!$object) Route::Throwable(HttpCode::NOT_FOUND, 'Not user');
        $this->repo->delete($pk);
        $this->renderJsonSuccess($pk);
    }

}
